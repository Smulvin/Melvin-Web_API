<header>
    <div>
        <a href="/"></a>
    </div>
</header>

<style>
    header {
        width: 100%;
        height: 10em;
        background: red;
        border-bottom: 20px solid black;
        position: relative;

        div {
            background: black;
            width: 150px;
            aspect-ratio: 1;
            border-radius: 50%;
            position: absolute;
            bottom: -50%;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            align-items: center;
            justify-content: center;

            &::after {
                content: "";
                position: absolute;

                inset: 15px;
                background: #ffffff;
                border-radius: 50%;
            }

            a {
                width: 90px;
                aspect-ratio: 1;
                background: white;
                border-radius: 2px solid #000000;
                border-radius: 50%;
                z-index: 1;
                box-shadow: 0 5px 5px gray;
                transition: 0.1s;

                &:active {
                    background: rgb(208, 208, 208);
                    box-shadow: 0 0 0 #808080;
                    transition: 0.1s;
                }
            }
        }
    }
</style>