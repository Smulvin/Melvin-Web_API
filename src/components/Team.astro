---

---
<dialogue id="team-panel" class="panel">
  <button id="toggle-btn">Team</button>

  <div class="panel-content">
    <h2>Your Team</h2>
    <ul id="team-list"></ul>
    <a class="play-btn" href="/play">Play</a>
  </div>
</dialogue>

<script>
  // @ts-nocheck

  document.addEventListener("DOMContentLoaded", () => {
    let team = Array(6).fill(null);

    const panel = document.getElementById("team-panel");
    const toggleBtn = document.getElementById("toggle-btn");
    const teamList = document.getElementById("team-list");

    if (!panel || !toggleBtn || !teamList) return;

    toggleBtn.onclick = () => {
      panel.classList.toggle("open");
    };

    // Load team
    const savedTeam = localStorage.getItem("pokemon-team");
    if (savedTeam) {
      team = JSON.parse(savedTeam);

      // safety fallback (in case older saves exist)
      if (!Array.isArray(team) || team.length !== 6) {
        team = Array(6).fill(null);
      }

      renderTeam();
    }

    function saveTeam() {
      localStorage.setItem("pokemon-team", JSON.stringify(team));
    }

    window.addToTeam = (pokemon) => {
      const index = team.findIndex((p) => p === null);

      if (index === -1) {
        alert("Team is full!");
        return;
      }

      team[index] = pokemon;
      saveTeam();
      renderTeam();
    };

    function removeFromTeam(index) {
      team[index] = null;
      saveTeam();
      renderTeam();
    }

    function renderTeam() {
      teamList.innerHTML = "";

      team.forEach((pokemon, index) => {
        const li = document.createElement("li");

        if (pokemon) {
          li.innerHTML = `
            <img src="${pokemon.image}" />
            <span>${pokemon.name}</span>
            <button class="remove-btn"><i class="fa-solid fa-minus"></i></button>
          `;

          li.querySelector(".remove-btn")?.addEventListener("click", () =>
            removeFromTeam(index),
          );
        } else {
          li.innerHTML = `<span class="empty"></span>`;
        }

        teamList.appendChild(li);
      });
    }
  });
</script>

<style>
  .panel {
    position: fixed;
    right: -400px;
    top: 50%;
    transform: translateY(-50%);
    width: 400px;
    background: var(--color-blue-light);
    border: 10px solid var(--color-blue-dark);
    border-right: none;
    corner-shape: bevel;
    border-radius: 50px 0 0 50px;
    color: white;
    transition: right 0.3s;
    padding: 1rem;
    z-index: 10;
    font-weight: bold;
  }

  .panel-content {
    padding: 10px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .panel.open {
    right: 0;
  }

  #toggle-btn {
    position: absolute;
    left: -87px;
    top: 50%;
    transform: translatex(-50%);
    cursor: pointer;
    background: var(--color-blue-light);
    color: white;
    border: 10px solid var(--color-blue-dark);
    border-top: 10px solid var(--color-blue-light);
    font-size: 1.5rem;
    rotate: 90deg;
    padding: 0.5rem 1rem;
    corner-shape: bevel;
    border-radius: 0px 0px 10px 10px;
    z-index: 11;
  }

  h2 {
    text-align: center;
  }

  ul {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;

    li {
      text-transform: capitalize;
      text-align: center;
      width: 100px;
      aspect-ratio: 1;
      position: relative;
      background: var(--color-blue-dark);
      border-radius: 50%;
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;

      img {
        width: 80%;
        height: 80%;
        object-fit: contain;
        display: block;
      }

      span {
        font-size: 16px;
        line-height: 1;
        text-align: center;
      }

      button {
        background: var(--color-red);
        position: absolute;
        top: -5px;
        right: -5px;
      }
    }
  }

  .panel-content ul {
    list-style: none;
  }

  .play-btn {
    background: var(--color-green);
    color: white;
    font-size: 1.25rem;
    font-weight: bold;
    padding: 1rem;
    border: 5px solid white;
    border-radius: 50px;
    cursor: pointer;
    text-align: center;
    text-decoration: none;
  }
</style>
