---
// @ts-nocheck
const { pokemonName } = Astro.props;

let pokemon = null;

try {
  const res = await fetch(
    `https://pokeapi.co/api/v2/pokemon/${pokemonName.toLowerCase()}`,
  );
  pokemon = await res.json();
} catch (err) {
  console.error("Error fetching Pokémon:", err);
}
---

{
  pokemon && (
    <a href={`/pokemon/${pokemon.name}`} class="card-link">
      <div class="card">
        <img
          src={pokemon.sprites.other["official-artwork"].front_default}
          alt={pokemon.name}
          class="image"
        />

        <h2 class="title">{pokemon.name}</h2>

        <div class="types">
          {pokemon.types.map((typeObj) => (
            <span class={`type type-${typeObj.type.name}`}>
              {typeObj.type.name}
            </span>
          ))}
        </div>
        <button
          class="add-btn"
          onclick={`event.stopPropagation(); event.preventDefault(); addToTeam({
          name: '${pokemon.name}',
          image: '${pokemon.sprites.other["official-artwork"].front_default}'
        })`}
        >
          <i class="fa-solid fa-plus" />
        </button>
      </div>
    </a>
  )
}

<style>
  .card-link {
    text-decoration: none;
  }

  .card {
    max-width: 200px;
    background: var(--detail-bg-light);
    border-radius: 1.6rem;
    border: 5px solid var(--detail-container-border);
    padding: 1rem 0;
    color: black;
    text-decoration: none;
    position: relative;
    
    img {
      aspect-ratio: 1;
      width: 90%;
      position: relative;
      border-radius: 50%;
      padding: 1rem;
      background: var(--detail-container-bg);
      border: 5px solid var(--detail-container-border);
      border-radius: 50%;
    }

    h2 {
      background: var(--detail-container-bg);
      border: 5px solid var(--detail-container-border);
      border-left: 0;
      corner-shape: bevel;
      border-radius: 0 0 5rem 0;
      width: 90%;
    }
  }

  .card button {
    background: var(--color-green);
    top: -1rem;
    right: -1rem;
  }

  .image {
    width: 128px;
    aspect-ratio: 1;
    display: block;
    margin: 0 auto;
    position: relative;
    z-index: 3;
  }

  .title {
    text-align: center;
    font-weight: bold;
    margin-top: 0.5rem;
    text-transform: capitalize;
    font-size: 1.25rem;
  }
</style>
