---
// @ts-nocheck
const { pokemonName } = Astro.props;

let pokemon = null;

try {
  const res = await fetch(
    `https://pokeapi.co/api/v2/pokemon/${pokemonName.toLowerCase()}`,
  );
  pokemon = await res.json();
} catch (err) {
  console.error("Error fetching Pokémon:", err);
}
---

{
  pokemon && (
    <a href={`/pokemon/${pokemon.name}`} class="card-link">
      <div class="card">
        <img
          src={pokemon.sprites.other["official-artwork"].front_default}
          alt={pokemon.name}
          class="image"
        />

        <h2 class="title">{pokemon.name}</h2>

        <div class="types">
          {pokemon.types.map((typeObj) => (
            <span class={`type type-${typeObj.type.name}`}>
              {typeObj.type.name}
            </span>
          ))}
        </div>
        <button
          class="add-btn"
          onclick={`event.stopPropagation(); event.preventDefault(); addToTeam({
          name: '${pokemon.name}',
          image: '${pokemon.sprites.other["official-artwork"].front_default}'
        })`}
        >
          <i class="fa-solid fa-plus" />
        </button>
      </div>
    </a>
  )
}

<script>
  // @ts-nocheck
  function handleMove(e) {
  const card = e.currentTarget;
  const rect = card.getBoundingClientRect();

  const x = e.clientX - rect.left;
  const y = e.clientY - rect.top;

  const centerX = rect.width / 2;
  const centerY = rect.height / 2;

  const rotateX = ((y - centerY) / centerY) * -8;
  const rotateY = ((x - centerX) / centerX) * 8;

  card.style.setProperty("--x", `${(x / rect.width) * 100}%`);
  card.style.setProperty("--y", `${(y / rect.height) * 100}%`);

  card.style.transform = `
    perspective(1000px)
    rotateX(${rotateX}deg)
    rotateY(${rotateY}deg)
    scale(1.03)
  `;
}

function reset(e) {
  const card = e.currentTarget;
  card.style.transform =
    "perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1)";
}
</script>

<style>
  .card-link {
    text-decoration: none;
  }

  .card {
    max-width: 200px;
    background:
        linear-gradient(135deg, var(--detail-bg-light) 0 50%, transparent 50%),
        linear-gradient(225deg, var(--detail-bg-normal) 0 50%, transparent 50%),
        linear-gradient(315deg, var(--detail-bg-dark) 0 50%, transparent 50%);
    border: 5px solid var(--detail-container-border);
    border-radius: 1.6rem;
    padding: 1rem 0;
    color: black;
    text-decoration: none;
    position: relative;
    
    img {
      aspect-ratio: 1;
      width: 90%;
      position: relative;
      border-radius: 50%;
      padding: 1rem;
      background: var(--detail-container-bg);
      border: 5px solid var(--detail-container-border);
      border-radius: 50%;
      transition: 0.3s;
    }

    h2 {
      background: var(--detail-container-bg);
      border: 5px solid var(--detail-container-border);
      border-left: 0;
      corner-shape: bevel;
      border-radius: 0 0 5rem 0;
    }

    &:hover img {
      scale: 1.1;
      animation: rotate 3s linear infinite;
      background: linear-gradient(
        180deg,
        var(--color-pokeball) 48%,
        var(--color-pokeball-rim) 48%,
        var(--color-pokeball-rim) 52%,
        var(--color-pokeball-bottom) 52%
      );
      transition: 0.3s;
    }
  }

  @keyframes rotate {
    0% {
      transform: rotate(0deg);
    }

    100% {
      transform: rotate(360deg);
    }
  }

  .card button {
    background: var(--color-green);
    top: -1rem;
    right: -1rem;
  }

  .image {
    width: 128px;
    aspect-ratio: 1;
    display: block;
    margin: 0 auto;
    position: relative;
    z-index: 3;
  }

  .title {
    text-align: center;
    font-weight: bold;
    margin-top: 0.5rem;
    text-transform: capitalize;
    font-size: 1.25rem;
  }
</style>
