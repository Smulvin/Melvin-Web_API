---
// @ts-nocheck
import DefaultLayout from "../../layouts/DefaultLayout.astro";
import { POKEMON_URL } from "../shared.js";

// Static paths
export async function getStaticPaths() {
  const res = await fetch(POKEMON_URL);
  const data = await res.json();

  return data.results.map((pokemon) => ({
    params: { name: pokemon.name },
  }));
}

// Main Pokémon
const { name } = Astro.params;
const res = await fetch(`https://pokeapi.co/api/v2/pokemon/${name}`);
const pokemon = await res.json();

// Allowed Pokémon
const allowedRes = await fetch(POKEMON_URL);
const allowedData = await allowedRes.json();
const allowedNames = allowedData.results.map((p) => p.name);

// Evolution chain
const species = await fetch(pokemon.species.url).then((r) => r.json());
const evoData = await fetch(species.evolution_chain.url).then((r) => r.json());

// Extract evolutions (only allowed Pokémon)
function extractEvolutions(chain) {
  const result = [];
  function traverse(node) {
    if (!node) return;
    const name = node.species.name;
    if (allowedNames.includes(name)) {
      const urlParts = node.species.url.split("/").filter(Boolean);
      const id = urlParts[urlParts.length - 1];
      result.push({
        name,
        id,
        sprite: `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/${id}.png`,
      });
    }
    node.evolves_to.forEach(traverse);
  }
  traverse(chain);
  return result;
}
const evolutionData = extractEvolutions(evoData.chain);
---

<DefaultLayout title={pokemon.name}>
  <div class="pokemon-info">
    <div class="detail-top">
      <div class="detail-name container">
        <h1>{pokemon.name}</h1>
        <p>#{pokemon.id}</p>
      </div>
      <div class="detail-types container">
        <ul>
          {
            pokemon.types?.map((t) => (
              <li class={`type type-${t.type.name}`}>{t.type.name}</li>
            ))
          }
        </ul>
      </div>
    </div>
    <div class="detail-main">
      <div class="detail-right">
        <div class="detail-image">
          <button
            class="container"
            onClick={() => new Audio(pokemon.cries?.latest).play()}
          >
            <img src={pokemon.sprites.front_default} alt={pokemon.name} />
          </button>

          <img
            class="container detail-shiny"
            src={pokemon.sprites.front_shiny}
            alt={`${pokemon.name} shiny`}
          />
        </div>
      </div>

      <div class="detail-left">
        <div class="detail-general container">
          <div class="detail-hg-wg">
            <div class="height">
              <p>Height</p>
              <p>{pokemon.height / 10} m</p>
            </div>
            <div class="weight">
              <p>Weight</p>
              <p>{pokemon.weight / 10} kg</p>
            </div>
          </div>
          <div class="abilities">
            <p>Abilities</p>
            <ul>
              {pokemon.abilities?.map((a) => <li>{a.ability.name}</li>)}
            </ul>
          </div>
        </div>

        <div class="detail-evolution">
          {
            evolutionData.map((evo) => (
              <a href={`/pokemon/${evo.name}`}>
                <img src={evo.sprite} alt={evo.name} />
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</DefaultLayout>

<style>
  /* Voorbeeld styling: https://www.instagram.com/reel/DXWxnvOjKeJ/?igsh=bW9kdzFqMjRlMnR5 */


  .pokemon-info {
    padding: 2rem 0;
    border: 5px solid var(--detail-container-border);
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin: 5rem auto;
    max-width: 80%;
    border-radius: 0.5rem;
    transform-origin: center;
    animation: pokedex-intro 700ms ease-out forwards;
    position: relative;

    &::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(135deg, var(--detail-bg-light) 0 50%, transparent 50%),
        linear-gradient(225deg, var(--detail-bg-normal) 0 50%, transparent 50%),
        linear-gradient(315deg, var(--detail-bg-dark) 0 50%, transparent 50%);
      z-index: -1;
    }
  }

  @keyframes pokedex-intro {
    0% {
      transform: scaleX(0.2) scaleY(0.05);
      opacity: 0;
    }

    35% {
      transform: scaleX(1) scaleY(0.05);
      opacity: 1;
    }

    65% {
      transform: scaleX(1) scaleY(0.05);
    }

    100% {
      transform: scaleX(1) scaleY(1);
    }
  }

  /* ===================== */
  /* TOP SECTION */
  /* ===================== */

  .detail-top {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .detail-name {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    font-size: clamp(1.5rem, 5vw, 3rem);
    font-weight: bold;
    height: 6rem;
    width: min(50%, 100%);
    corner-shape: bevel;
    border-radius: 0 6rem 0 0;
    overflow: hidden;

    h1 {
      order: 2;
      text-transform: capitalize;
      font-size: inherit;
    }
  }

  /* ===================== */
  /* TYPES */
  /* ===================== */

  .detail-types {
    height: 6rem;
    width: clamp(10rem, 25%, 18rem);
    corner-shape: bevel;
    border-radius: 0 0 0 6rem;
    overflow: hidden;

    ul {
      display: flex;
      gap: 1rem;
      justify-content: flex-end;
      align-items: center;
      list-style: none;
      height: 100%;
      padding: 1rem;
      margin: 0;

      li {
        font-size: clamp(0.9rem, 2vw, 1.5rem);
        text-transform: capitalize;
      }
    }
  }

  /* =========== */
  /* MAIN LAYOUT */
  /* =========== */

  .detail-main {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
    align-items: start;
  }

  /* ===================== */
  /* GENERAL INFO CARD */
  /* ===================== */

  .detail-general {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    corner-shape: bevel;
    border-radius: 0 0 0 30rem;
    padding: 2rem;
    align-items: flex-end;

    .detail-hg-wg {
      display: flex;
      gap: 5rem;

      div {
        display: flex;
        flex-direction: column;
      }
    }

    p {
      font-size: clamp(1.2rem, 2vw, 1.8rem);
    }

    p:first-of-type {
      font-weight: bold;
      font-size: clamp(1.5rem, 2vw, 3rem);
    }

    li {
      list-style: none;
      text-transform: capitalize;
      font-size: clamp(1.2rem, 2vw, 1.8rem);
    }
  }

  /* ===================== */
  /* EVOLUTION */
  /* ===================== */

  .detail-evolution {
    display: flex;
    justify-content: space-evenly;
    flex-wrap: wrap;
    text-decoration: none;
    width: 100%;
    

    a {
      position: relative;

      &::before {
        content: "";
        position: absolute;
        inset: 1rem;
        aspect-ratio: 1;
        background: var(--detail-container-bg);
        border: 5px solid var(--detail-container-border);
        border-radius: 50%;
        z-index: 0;
      }
    }

    img {
      width: 10rem;
      aspect-ratio: 1;
      object-fit: contain;
      position: relative;
      z-index: 1;
    }
  }

  /* ===================== */
  /* IMAGE SECTION */
  /* ===================== */

  .detail-right {
    position: relative;
    margin: 2rem;

    button {
      border-radius: 50%;
      width: 100%;
      aspect-ratio: 1;

      img {
        width: 80%;
      }
    }
  }

  .detail-shiny {
    border-radius: 50%;
    width: 30%;
    position: absolute;
    bottom: 0;
    right: 0;
  }

  /* ===================== */
  /* CONTAINER STYLE */
  /* ===================== */

  .pokemon-info .container {
    background: var(--detail-container-bg);
    border: 5px solid var(--detail-container-border);
  }
</style>
