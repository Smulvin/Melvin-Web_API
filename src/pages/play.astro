---
// @ts-nocheck
import DefaultLayout from "../layouts/DefaultLayout.astro";
---

<DefaultLayout title="Play">
  <h1>Play in AR!</h1>

  <div class="camera-box">
    <video id="video" autoplay playsinline></video>

    <!-- Overlay layer -->
    <div class="overlay">
      <img id="pokemon" src="" />

      <button id="team-toggle" class="team-toggle">Team</button>
      <div id="team-menu" class="team-menu"></div>
      <template id="team-item-template">
        <div class="team-item">
          <img class="team-sprite" />
        </div>
      </template>

      <button class="location-btn" id="pos-left">Left</button>
      <button class="location-btn" id="pos-right">Right</button>
      <button class="location-btn" id="pos-top">Top</button>

      <button id="start-camera">Start Camera</button>
    </div>
  </div>

  <!-- Code voor het laten werken van de AR is gegeneerd door ChatGPT 
  Prompt:
  Right it just places the pokemon sprite on the video overlay, but it is not
  according to the user on the camera. Do you have an Web API that can make that
  happen? Give me the full script  -->
  <script type="module">
    import "https://cdn.jsdelivr.net/npm/@mediapipe/face_detection/face_detection.js";
    import "https://cdn.jsdelivr.net/npm/@mediapipe/camera_utils/camera_utils.js";

    const btn = document.getElementById("start-camera");
    const video = document.getElementById("video");

    const pokemon = document.getElementById("pokemon");
    const switchBtn = document.getElementById("switch-pokemon");

    const btnLeft = document.getElementById("pos-left");
    const btnRight = document.getElementById("pos-right");
    const btnTop = document.getElementById("pos-top");

    // 🎯 Position control
    let position = "right";

    btnLeft?.addEventListener("click", () => (position = "left"));
    btnRight?.addEventListener("click", () => (position = "right"));
    btnTop?.addEventListener("click", () => (position = "top"));

    // 🎮 Load team
    let team = [];
    let selected = 0;

    try {
      const savedTeam = localStorage.getItem("pokemon-team");
      if (savedTeam) {
        const parsed = JSON.parse(savedTeam);
        if (Array.isArray(parsed) && parsed.length === 6) {
          team = parsed;
        }
      }
    } catch (e) {
      console.error("Failed to load team:", e);
    }

    function getValidTeam() {
      return (team || []).filter((p) => p && typeof p === "object");
    }

    async function setPokemonImage() {
      const validTeam = getValidTeam();

      if (validTeam.length === 0) {
        pokemon.style.display = "none";
        return;
      }

      if (selected >= validTeam.length) selected = 0;

      const current = validTeam[selected];
      pokemon.style.display = "block";

      try {
        const res = await fetch(
          `https://pokeapi.co/api/v2/pokemon/${current.name || current.id}`,
        );
        const data = await res.json();
        pokemon.src = data.sprites.front_default;
      } catch (err) {
        console.error("Failed to load sprite:", err);
        pokemon.src = current.image;
      }
    }

    switchBtn?.addEventListener("click", () => {
      const validTeam = getValidTeam();
      if (validTeam.length === 0) return;

      selected = (selected + 1) % validTeam.length;
      setPokemonImage();
    });

    // 🧠 Face detection
    const faceDetection = new window.FaceDetection({
      locateFile: (file) =>
        `https://cdn.jsdelivr.net/npm/@mediapipe/face_detection/${file}`,
    });

    faceDetection.setOptions({
      model: "short",
      minDetectionConfidence: 0.5,
    });

    // 🎯 Track face → position EVERYTHING proportionally
    faceDetection.onResults((results) => {
      if (!results.detections.length) return;

      const detection = results.detections[0];
      const box = detection.boundingBox;

      const x = box.xCenter;
      const y = box.yCenter;

      const left = x * 100;
      const top = y * 100;

      // 📏 Face size (relative → %)
      const videoWidth = video.videoWidth;
      const videoHeight = video.videoHeight;

      const faceWidthPx = box.width * videoWidth;
      const faceHeightPx = box.height * videoHeight;

      // keep % for positioning
      const faceWidth = box.width * 100;
      const faceHeight = box.height * 100;

      // 🎯 Scaled offsets
      const shoulderOffsetX = faceWidth * 1;
      const shoulderOffsetY = faceHeight * 0.5;
      const headOffsetY = faceHeight * 1.2;

      // 🎮 Move buttons with face
      btnLeft.style.left = `${left - shoulderOffsetX}%`;
      btnLeft.style.top = `${top + shoulderOffsetY}%`;

      btnRight.style.left = `${left + shoulderOffsetX}%`;
      btnRight.style.top = `${top + shoulderOffsetY}%`;

      btnTop.style.left = `${left}%`;
      btnTop.style.top = `${top - headOffsetY}%`;

      // 🐱 Pokémon positioning
      let offsetX = 0;
      let offsetY = 0;

      switch (position) {
        case "left":
          offsetX = -shoulderOffsetX;
          offsetY = shoulderOffsetY;
          pokemon.style.width = `${faceWidth * 20}px`;
          break;

        case "right":
          offsetX = shoulderOffsetX;
          offsetY = shoulderOffsetY;
          pokemon.style.width = `${faceWidth * 20}px`;
          break;

        case "top":
          offsetX = 0;
          offsetY = -headOffsetY;
          pokemon.style.width = `${faceWidth * 16}px`;
          break;
      }

      pokemon.style.left = `${left + offsetX}%`;
      pokemon.style.top = `${top + offsetY}%`;
    });

    // 📷 Start camera
    btn?.addEventListener("click", async () => {
      try {
        const stream = await navigator.mediaDevices.getUserMedia({
          video: true,
          audio: false,
        });

        video.srcObject = stream;
        await video.play();

        const camera = new window.Camera(video, {
          onFrame: async () => {
            await faceDetection.send({ image: video });
          },
          width: 600,
          height: 400,
        });

        camera.start();

        // ✅ Hide start button
        btn.style.display = "none";

        // ✅ Activate AR UI properly (THIS is the fix)
        document.querySelector(".overlay").classList.add("ar-active");
      } catch (err) {
        console.error(err);
        alert("Camera access denied or not available.");
      }

      setPokemonImage();
    });

    // Team Select
    const teamToggle = document.getElementById("team-toggle");
    const teamMenu = document.getElementById("team-menu");
    const template = document.getElementById("team-item-template");

    let menuOpen = false;

    teamToggle?.addEventListener("click", () => {
      menuOpen = !menuOpen;

      if (menuOpen) {
        teamMenu.classList.add("open");
        renderTeamMenu();
      } else {
        teamMenu.classList.remove("open");
      }
    });

    async function renderTeamMenu() {
      const validTeam = getValidTeam();
      teamMenu.innerHTML = "";

      for (let i = 0; i < validTeam.length; i++) {
        const p = validTeam[i];

        let imgSrc = p.image;

        try {
          const res = await fetch(
            `https://pokeapi.co/api/v2/pokemon/${p.name || p.id}`,
          );
          const data = await res.json();
          imgSrc = data.sprites.front_default;
        } catch (e) {
          console.warn("Sprite fallback used");
        }

        // ✅ Clone template
        const clone = template.content.cloneNode(true);

        const item = clone.querySelector(".team-item");
        const img = clone.querySelector(".team-sprite");

        img.src = imgSrc;

        item.addEventListener("click", () => {
          selected = i;
          setPokemonImage();
        });

        teamMenu.appendChild(clone);
      }
    }
  </script>

  <style>
    h1 {
      text-align: center;
      color: white;
      margin: 5rem 0 2rem 0;
    }

    .camera-box {
      position: relative;
      width: 80%;
      aspect-ratio: 1920 / 1080;
      overflow: hidden;
      border-radius: 12px;
      margin: 1rem auto;
    }

    video {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .overlay {
      position: absolute;
      inset: 0;

      .location-btn {
        position: absolute;
        transform: translate(-50%, -50%);
        padding: 7rem;
        cursor: pointer;
        opacity: 0;
      }
    }

    #pokemon {
      position: absolute;
      width: 250px;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      transition:
        left 0.1s linear,
        top 0.1s linear;
    }

    /* hidden unless AR is active */
.team-toggle,
.team-menu {
  display: none;
}

/* AR mode ON */
.overlay.ar-active .team-toggle {
  display: block;
}

/* menu base (no display here anymore!) */
.team-menu {
  position: absolute;
  flex-direction: column;
  gap: 0.5rem;
  z-index: 20;
}

/* ONLY open state controls visibility */
.team-menu.open {
  display: flex;
}

.team-item {
  background: var(--color-blue-light);
  border-radius: 50%;
}

    #start-camera {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      color: white;
      background: var(--color-green);
      padding: 1rem 2rem;
      border-radius: 50px;
      cursor: pointer;
      border: 5px solid white;
      font-weight: bold;
      font-size: 2rem;
    }
  </style>
</DefaultLayout>
