---
// @ts-nocheck
import DefaultLayout from "../layouts/DefaultLayout.astro";
---

<DefaultLayout title="Play">
  <h1>Play in AR!</h1>

  <div class="camera-box">
    <video id="video" autoplay playsinline></video>

    <!-- Overlay layer -->
    <div class="overlay">
      <img id="pokemon" src="" />
      <div id="particles"></div>

      <button id="team-toggle" class="team-toggle">
        <div></div>
      </button>
      <div id="team-menu" class="team-menu"></div>
      <template id="team-item-template">
        <div class="team-item">
          <img class="team-sprite" />
        </div>
      </template>

      <button class="location-btn" id="pos-left">Left</button>
      <button class="location-btn" id="pos-right">Right</button>
      <button class="location-btn" id="pos-top">Top</button>

      <button id="start-camera">Start Camera</button>
    </div>
  </div>

  <!-- Code voor het laten werken van de AR is gegeneerd door ChatGPT 
  Prompt:
  Right now it just places the pokemon sprite on the video overlay, but it is not
  according to the user on the camera. Do you have an Web API that can make that
  happen? Give me the full script  -->
  <script type="module">
    import "https://cdn.jsdelivr.net/npm/@mediapipe/face_detection/face_detection.js";
    import "https://cdn.jsdelivr.net/npm/@mediapipe/camera_utils/camera_utils.js";

    // ─────────────────────────────
    // 1. DOM + STATE
    // ─────────────────────────────
    const $ = (id) => document.getElementById(id);

    const videoElement = $("video");
    const startCameraButton = $("start-camera");

    const pokemonImage = $("pokemon");

    const teamToggleButton = $("team-toggle");
    const teamMenu = $("team-menu");
    const teamItemTemplate = $("team-item-template");

    const positionLeftButton = $("pos-left");
    const positionRightButton = $("pos-right");
    const positionTopButton = $("pos-top");

    let selectedPosition = "right";
    let selectedPokemonIndex = 0;
    let isTeamMenuOpen = false;

    positionLeftButton.onclick = () => (selectedPosition = "left");
    positionRightButton.onclick = () => (selectedPosition = "right");
    positionTopButton.onclick = () => (selectedPosition = "top");

    // ─────────────────────────────
    // 2. TEAM + POKÉMON
    // ─────────────────────────────
    const team = JSON.parse(localStorage.getItem("pokemon-team") || "[]");

    const getValidTeam = () => team.filter(Boolean);

    async function fetchPokemonData(pokemon) {
      try {
        const res = await fetch(
          `https://pokeapi.co/api/v2/pokemon/${pokemon.name || pokemon.id}`,
        );
        const data = await res.json();

        return {
          sprite: data.sprites.front_default,
          type: data.types[0].type.name, // 👈 primary type
        };
      } catch {
        return {
          sprite: pokemon.image,
          type: "normal",
        };
      }
    }

    async function updateDisplayedPokemon() {
      const validTeam = getValidTeam();
      if (!validTeam.length) return;

      selectedPokemonIndex %= validTeam.length;

      const { sprite, type } = await fetchPokemonData(
        validTeam[selectedPokemonIndex],
      );

      pokemonImage.style.display = "block";
      pokemonImage.src = sprite;

      triggerParticles(type);
    }

    teamToggleButton.onclick = () => {
      isTeamMenuOpen = !isTeamMenuOpen;

      teamMenu.classList.toggle("open", isTeamMenuOpen);
      teamToggleButton.classList.toggle("active", isTeamMenuOpen);

      if (isTeamMenuOpen) renderTeamMenu();
    };

    async function renderTeamMenu() {
      const validTeam = getValidTeam();
      teamMenu.innerHTML = "";

      for (let i = 0; i < validTeam.length; i++) {
        const pokemon = validTeam[i];

        const { sprite } = await fetchPokemonData(pokemon);

        const spriteImg = document.createElement("img");
        spriteImg.className = "team-sprite";
        spriteImg.src = sprite;

        const menuItem =
          teamItemTemplate.content.firstElementChild.cloneNode(true);
        menuItem.querySelector("img").replaceWith(spriteImg);

        menuItem.onclick = () => {
          selectedPokemonIndex = i;
          updateDisplayedPokemon();
        };

        teamMenu.appendChild(menuItem);
      }
    }

    // ─────────────────────────────
    // 3. CAMERA + FACE TRACKING
    // ─────────────────────────────
    const faceDetection = new window.FaceDetection({
      locateFile: (file) =>
        `https://cdn.jsdelivr.net/npm/@mediapipe/face_detection/${file}`,
    });

    faceDetection.setOptions({
      model: "short",
      minDetectionConfidence: 0.5,
    });

    faceDetection.onResults(({ detections }) => {
      if (!detections.length) return;

      const face = detections[0].boundingBox;

      // Face center in percentage of screen
      const faceCenterX = face.xCenter * 100;
      const faceCenterY = face.yCenter * 100;

      // Face size in percentage
      const faceWidthPct = face.width * 100;
      const faceHeightPct = face.height * 100;

      // Offsets based on face size
      const sideOffset = faceWidthPct;
      const eyeLevelOffset = faceHeightPct * 0.5;
      const aboveHeadOffset = faceHeightPct * 1.6;

      // Position helper buttons around face
      positionLeftButton.style.left = `${faceCenterX - sideOffset}%`;
      positionLeftButton.style.top = `${faceCenterY + eyeLevelOffset}%`;

      positionRightButton.style.left = `${faceCenterX + sideOffset}%`;
      positionRightButton.style.top = `${faceCenterY + eyeLevelOffset}%`;

      positionTopButton.style.left = `${faceCenterX}%`;
      positionTopButton.style.top = `${faceCenterY - aboveHeadOffset}%`;

      // Pokémon offset depending on selected position
      let offsetX = 0;
      let offsetY = 0;

      if (selectedPosition === "left") {
        offsetX = -sideOffset;
        offsetY = eyeLevelOffset;
      }

      if (selectedPosition === "right") {
        offsetX = sideOffset;
        offsetY = eyeLevelOffset;
      }

      if (selectedPosition === "top") {
        offsetX = 0;
        offsetY = -aboveHeadOffset;
      }

      pokemonImage.style.width =
        selectedPosition === "top"
          ? `${faceWidthPct * 16}px`
          : `${faceWidthPct * 20}px`;

      pokemonImage.style.left = `${faceCenterX + offsetX}%`;
      pokemonImage.style.top = `${faceCenterY + offsetY}%`;
    });

    // ─────────────────────────────
    // 4. START CAMERA
    // ─────────────────────────────
    startCameraButton.onclick = async () => {
      const stream = await navigator.mediaDevices.getUserMedia({
        video: true,
      });

      videoElement.srcObject = stream;
      await videoElement.play();

      const camera = new window.Camera(videoElement, {
        onFrame: async () => faceDetection.send({ image: videoElement }),
      });

      camera.start();

      startCameraButton.style.display = "none";
      document.querySelector(".overlay").classList.add("ar-active");

      updateDisplayedPokemon();
    };

    // ─────────────────────────────
    // 5. PARTICLES
    // ─────────────────────────────

    // ChatGPT heeft geholpen deze functie te schrijven, eerst had ik hem gevraagd om hem alleen te maken, daarna om hem aan te passen zodat ik makkelijker de waardes kon aanpassen. 
    // Bij beide prompts gaf ik een stuk code mee als context
    // Prompp 1: Create a particles system that shoots out of the center of the pokemon like a burst in the color of their primary typing.
    // Prompt 2: Could you change the function so that I have a clear list at the top for tweaking the particles? THink about lifetime, amount, size, speed.
    function getTypeColor(type) {
      const value = getComputedStyle(document.documentElement)
        .getPropertyValue(`--color-${type}`)
        .trim();

      return value || "#ff0000";
    }

    function triggerParticles(type) {
      // ─────────────────────────────
      // 🎛️ PARTICLE CONFIG (tweak here)
      // ─────────────────────────────
      const PARTICLE_CONFIG = {
        count: 50, // how many particles
        size: 30, // px
        lifetime: 600, // ms (must match animation + cleanup)
        spread: 300, // max explosion radius
        minSpread: 100, // min explosion radius
        zIndex: 9999,
        easing: "ease-out",
        alphaStart: 1,
        alphaEnd: 0,
        scaleEnd: 0.3,
      };

      const container = document.getElementById("particles");
      container.innerHTML = "";

      const color = getTypeColor(type);

      const rect = pokemonImage.getBoundingClientRect();
      const containerRect = container.getBoundingClientRect();

      const centerX = rect.left - containerRect.left + rect.width / 2;
      const centerY = rect.top - containerRect.top + rect.height / 2;

      for (let i = 0; i < PARTICLE_CONFIG.count; i++) {
        const particle = document.createElement("div");

        // base styling
        particle.style.position = "absolute";
        particle.style.width = `${PARTICLE_CONFIG.size}px`;
        particle.style.height = `${PARTICLE_CONFIG.size}px`;
        particle.style.borderRadius = "50%";
        particle.style.background = color;
        particle.style.left = `${centerX}px`;
        particle.style.top = `${centerY}px`;
        particle.style.pointerEvents = "none";
        particle.style.zIndex = PARTICLE_CONFIG.zIndex;

        container.appendChild(particle);

        // movement math
        const angle = Math.random() * Math.PI * 2;
        const distance =
          Math.random() * (PARTICLE_CONFIG.spread - PARTICLE_CONFIG.minSpread) +
          PARTICLE_CONFIG.minSpread;

        const x = Math.cos(angle) * distance;
        const y = Math.sin(angle) * distance;

        particle.animate(
          [
            {
              transform: "translate(0,0) scale(1)",
              opacity: PARTICLE_CONFIG.alphaStart,
            },
            {
              transform: `translate(${x}px, ${y}px) scale(${PARTICLE_CONFIG.scaleEnd})`,
              opacity: PARTICLE_CONFIG.alphaEnd,
            },
          ],
          {
            duration: PARTICLE_CONFIG.lifetime,
            easing: PARTICLE_CONFIG.easing,
          },
        );

        setTimeout(() => particle.remove(), PARTICLE_CONFIG.lifetime);
      }
    }
  </script>

  <style>
    h1 {
      text-align: center;
      color: white;
      margin: 5rem 0 2rem 0;
    }

    .camera-box {
      position: relative;
      width: 80%;
      aspect-ratio: 1920 / 1080;
      overflow: hidden;
      border-radius: 12px;
      margin: 1rem auto;
    }

    video {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .overlay {
      position: absolute;
      inset: 0;

      .location-btn {
        position: absolute;
        transform: translate(-50%, -50%);
        padding: 7rem;
        opacity: 0;
      }
    }

    #pokemon {
      position: absolute;
      width: 250px;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      z-index: 5;
      transition:
        left 0.1s linear,
        top 0.1s linear;
    }

    .team-toggle,
    .team-menu {
      display: none;
    }

    .overlay.ar-active .team-toggle {
      display: block;
    }

    .team-menu {
      position: absolute;
      flex-direction: column;
      gap: 0.5rem;
      z-index: 20;
    }

    .team-menu.open {
      display: flex;
    }

    .team-item {
      background: var(--detail-container-bg);
      border: 3px solid var(--detail-container-border);
      border-radius: 50%;
    }

    #start-camera {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      color: white;
      background: var(--color-green);
      padding: 1rem 2rem;
      border-radius: 50px;
      border: 5px solid white;
      font-weight: bold;
      font-size: 2rem;
    }

    .team-toggle {
      aspect-ratio: 1;
      width: 5rem;
      position: relative;
      margin: 1rem;
      border-radius: 50%;
      border: none;

      div:before {
        content: "";
        position: absolute;
        height: 50%;
        top: 0;
        left: 0;
        width: 100%;
        background: red;
        border-radius: 50px 50px 0 0;
      }

      div:after {
        content: "";
        position: absolute;
        height: 30%;
        aspect-ratio: 1;
        background: white;
        border: 2px solid black;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        border-radius: 50%;
      }
    }

    .team-toggle.active {
      div:before {
        transform: translateY(-20%) scaleY(0.9);
        box-shadow: 0 10px 0 gray;
      }

      div:after {
        transform: translate(-50%, -70%) scaleY(0.9);
      }
    }
  </style>
</DefaultLayout>
